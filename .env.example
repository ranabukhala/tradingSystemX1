# ─────────────────────────────────────────────────────────────
#  US Equities Trading System — Environment Configuration
#  Copy to .env and fill in your values. NEVER commit .env
# ─────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=tradingpass
POSTGRES_DB=trading_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://trading:tradingpass@localhost:5432/trading_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_DEDUP_TTL_SECONDS=86400        # 24h dedup window

# ── Redpanda / Kafka ──────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_GROUP_ID=trading-pipeline

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false
MINIO_BUCKET_FULLTEXT=news-fulltext
MINIO_BUCKET_RAW=news-raw-payloads
MINIO_BUCKET_SUMMARIES=summaries
MINIO_BUCKET_SNAPSHOTS=snapshots

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ── Vendor API Keys ───────────────────────────────────────────
# Benzinga: https://www.benzinga.com/apis/
BENZINGA_API_KEY=your_benzinga_api_key_here

# Polygon.io: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Earnings Whispers: https://www.earningswhispers.com/api
EARNINGS_WHISPERS_API_KEY=your_earnings_whispers_key_here

# FRED (St. Louis Fed): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# Free tier: 25 req/day → set ALPHAVANTAGE_POLL_INTERVAL_SECONDS=3600
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here
ALPHAVANTAGE_POLL_INTERVAL_SECONDS=300

# Financial Modeling Prep: https://financialmodelingprep.com/
# Plans: free (250 req/day) | starter | premium — set FMP_PLAN accordingly
FMP_API_KEY=your_fmp_api_key_here
FMP_PLAN=free

# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Pipeline Settings ─────────────────────────────────────────
BENZINGA_POLL_INTERVAL_SECONDS=30
POLYGON_NEWS_POLL_INTERVAL_SECONDS=60
EARNINGS_SYNC_HOUR_ET=6              # Daily earnings sync at 6 AM ET
EARNINGS_LOOKAHEAD_DAYS=30

# Market hours (ET)
MARKET_PREMARKET_START=04:00
MARKET_OPEN=09:30
MARKET_CLOSE=16:00
MARKET_AFTERHOURS_END=20:00

# ── LLM Cost Controls ─────────────────────────────────────────
LLM_DAILY_BUDGET_USD=25.00
LLM_T2_IMPACT_THRESHOLD=0.6         # Only run T2 if impact_day > this
LLM_FULLTEXT_IMPACT_THRESHOLD=0.7   # Only fetch full text if impact_day > this

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
METRICS_PORT=8000                    # Prometheus metrics endpoint port
ENVIRONMENT=development
