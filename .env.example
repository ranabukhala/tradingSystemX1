# ─────────────────────────────────────────────────────────────
#  US Equities Trading System — Environment Configuration
#  Copy to .env and fill in your values. NEVER commit .env
# ─────────────────────────────────────────────────────────────

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=tradingpass
POSTGRES_DB=trading_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://trading:tradingpass@localhost:5432/trading_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_DEDUP_TTL_SECONDS=86400

# ── Redpanda / Kafka ──────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_GROUP_ID=trading-pipeline

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost:9000

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ── Vendor API Keys ───────────────────────────────────────────
BENZINGA_API_KEY=your_benzinga_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here
EARNINGS_WHISPERS_API_KEY=your_earnings_whispers_key_here
FRED_API_KEY=your_fred_api_key_here
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here
FMP_API_KEY=your_fmp_api_key_here
FMP_PLAN=free
FINNHUB_API_KEY=your_finnhub_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Broker ────────────────────────────────────────────────────
# Options: alpaca_paper | alpaca_live | ibkr_paper | ibkr_live
BROKER=alpaca_paper
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
IBKR_HOST=host.docker.internal
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# ── Trading Safety (CRITICAL) ────────────────────────────────
# Must be explicitly set to "true" for live trading
CONFIRM_LIVE_TRADING=false

# ── Risk Controls ─────────────────────────────────────────────
RISK_MAX_POSITION_PCT=0.02
RISK_MAX_POSITION_USD=5000
RISK_MAX_DAILY_LOSS_PCT=0.05
RISK_MAX_OPEN_POSITIONS=10
RISK_MIN_CONVICTION=0.40
RISK_ALLOW_PREMARKET=true
RISK_TAKE_PROFIT_PCT=0.10
RISK_STOP_LOSS_PCT=0.04
RISK_USE_BRACKET_ORDERS=true
RISK_MAX_ORDERS_PER_HOUR=20
RISK_MAX_ORDERS_PER_DAY=120
RISK_CONSECUTIVE_LOSS_HALT=5
RISK_DAILY_LOSS_CAP_USD=2000
RISK_COOLDOWN_AFTER_LOSS_MINUTES=30
RISK_MIN_AVG_VOLUME=100000
RISK_MAX_SPREAD_PCT=0.02

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=

# ── Pipeline Settings ─────────────────────────────────────────
BENZINGA_POLL_INTERVAL_SECONDS=30
POLYGON_NEWS_POLL_INTERVAL_SECONDS=60
ALPHAVANTAGE_POLL_INTERVAL_SECONDS=300

# ── LLM Cost Controls ─────────────────────────────────────────
LLM_DAILY_BUDGET_USD=25.00
LLM_T2_IMPACT_THRESHOLD=0.6

# ── Signal Thresholds ─────────────────────────────────────────
SIGNAL_CONVICTION_THRESHOLD=0.55
SIGNAL_ALERT_THRESHOLD=0.60

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=INFO
METRICS_PORT=8000
ENVIRONMENT=development

# ── SQLite State DB ───────────────────────────────────────────
DATA_DIR=/data
